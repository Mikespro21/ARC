from __future__ import annotations
from dataclasses import dataclass
from typing import Dict, Any
import streamlit as st

@dataclass(frozen=True)
class Step:
    n: int
    title: str
    body: str
    page: str
    target_key: str

TOTAL = 7

STEPS: Dict[int, Step] = {
    1: Step(1, "Welcome", "Click the main CTA to start. We’ll guide Agent → Market → Execute → Wallet.", "home", "cta_automate"),
    2: Step(2, "Agent plan", "Click “Generate a plan”.", "coach", "coach_plan"),
    3: Step(3, "Go Market", "Click “Go to Market”.", "coach", "coach_to_market"),
    4: Step(4, "Pick asset", "Choose an asset to trade.", "market", "mkt_asset"),
    5: Step(5, "Execute", "Execute one demo trade so you learn the flow.", "market", "mkt_exec"),
    6: Step(6, "Save wallet", "Save your wallet so we can link ArcScan proof.", "profile", "pf_save"),
    7: Step(7, "Done", "You’re ready: Agent → Market → Execute → Track.", "home", "nav_home"),
}

def _set_step(n: int) -> None:
    st.session_state["tour_step"] = max(1, min(TOTAL, int(n)))

def tour_complete_step(n: int) -> None:
    cur = int(st.session_state.get("tour_step", 1))
    if n == cur:
        if cur >= TOTAL:
            st.session_state["tour_done"] = True
        else:
            _set_step(cur + 1)
        st.rerun()

def _finish(user: Dict[str, Any]) -> None:
    user["tutorial_done"] = True
    st.session_state["tour_done"] = True
    try:
        from crowdlike.auth import save_current_user
        save_current_user()
    except Exception:
        pass

def _spotlight_css(target_key: str) -> None:
    # This highlights the target area if Streamlit renders #st-key-<key>.
    st.markdown(
        f"""
        <style>
        /* small dim (visual only, doesn't block clicks) */
        .tour-dim {{
            position: fixed; inset: 0;
            background: rgba(2,6,23,0.25);
            pointer-events: none;
            z-index: 9990;
        }}
        .tour-card {{
            border-radius: 12px;
            border: 1px solid rgba(167,139,250,0.22);
            background: rgba(255,255,255,0.92);
            box-shadow: 0 18px 70px rgba(2,6,23,0.16);
            padding: 12px 12px 10px 12px;
        }}
        .tour-topline {{
            height: 3px; border-radius: 999px;
            background: linear-gradient(90deg, rgba(14,165,233,0.55), rgba(167,139,250,0.70));
            margin-bottom: 10px;
        }}
        .tour-kicker {{
            font-size: 0.78rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: rgba(71,85,105,0.92);
            margin-bottom: 4px;
        }}
        .tour-title {{
            font-weight: 820;
            font-size: 1.02rem;
            margin-bottom: 6px;
            color: rgba(15,23,42,0.95);
        }}
        .tour-body {{
            color: rgba(51,65,85,0.95);
            line-height: 1.45;
            font-size: 0.95rem;
            margin-bottom: 10px;
        }}

        /* spotlight */
        #st-key-{target_key} {{
            position: relative !important;
            z-index: 9992 !important;
        }}
        #st-key-{target_key} button,
        #st-key-{target_key} input,
        #st-key-{target_key} textarea,
        #st-key-{target_key} a {{
            box-shadow: 0 0 0 3px rgba(167,139,250,0.22), 0 18px 50px rgba(2,6,23,0.22) !important;
        }}
        </style>
        <div class="tour-dim"></div>
        """,
        unsafe_allow_html=True
    )

def maybe_run_tour(user: Dict[str, Any] | None, current_page: str) -> None:
    if not user:
        return
    if user.get("tutorial_done") or st.session_state.get("tour_done"):
        return

    step = int(st.session_state.get("tour_step", 1))
    _set_step(step)

    s = STEPS[step]
    _spotlight_css(s.target_key)

    # Always-visible controls INSIDE the tour card (so “Next” is never missing)
    st.markdown('<div class="tour-card"><div class="tour-topline"></div>', unsafe_allow_html=True)
    st.markdown(f'<div class="tour-kicker">Step {step} of {TOTAL}</div>', unsafe_allow_html=True)
    st.markdown(f'<div class="tour-title">{s.title}</div>', unsafe_allow_html=True)
    st.markdown(f'<div class="tour-body">{s.body}</div>', unsafe_allow_html=True)
    st.markdown(
        '<div style="color: rgba(71,85,105,0.92); font-size: 0.90rem; margin-bottom: 8px;">'
        'Do the highlighted action to auto-continue, or use Next.'
        '</div>',
        unsafe_allow_html=True
    )

    c1, c2, c3, c4 = st.columns([1, 1, 1, 1])
    with c1:
        if st.button("Skip", key="tour_skip", use_container_width=True):
            _finish(user); st.rerun()
    with c2:
        if st.button("Back", key="tour_back", disabled=(step <= 1), use_container_width=True):
            _set_step(step - 1); st.rerun()
    with c3:
        if step < TOTAL:
            if st.button("Next", key="tour_next", use_container_width=True):
                _set_step(step + 1); st.rerun()
        else:
            st.write("")  # keep layout
    with c4:
        if step >= TOTAL:
            if st.button("Finish", key="tour_finish", use_container_width=True):
                _finish(user); st.rerun()

    st.markdown("</div>", unsafe_allow_html=True)
